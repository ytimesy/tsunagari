<section class="form-panel cute-frame">
  <p class="ribbon-label">Encounter Case</p>
  <h1><%= @encounter_case.new_record? ? "出会い事例を作成" : "出会い事例を編集" %></h1>

  <% if @encounter_case.errors.any? %>
    <div class="error-summary">
      <p>入力内容を確認してください。</p>
      <ul>
        <% @encounter_case.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @encounter_case, url: @encounter_case.new_record? ? encounter_cases_path : encounter_case_path(@encounter_case), data: { controller: "tag-catalog" } do |form| %>
    <div class="field">
      <%= form.label :title, "事例タイトル" %>
      <%= form.text_field :title, required: true, placeholder: "研究者と地域が出会い、新しい実験が始まった" %>
    </div>

    <div class="field">
      <%= form.label :summary, "要約" %>
      <%= form.text_area :summary, rows: 3, placeholder: "何が起きた事例なのかを短くまとめます。" %>
    </div>

    <div class="field">
      <%= form.label :background, "背景" %>
      <%= form.text_area :background, rows: 8, placeholder: "出会いの背景、文脈、前提条件を書きます。" %>
    </div>

    <div class="field">
      <%= form.label :happened_on, "起きた日" %>
      <%= form.date_field :happened_on %>
    </div>

    <div class="field">
      <%= form.label :place, "場所" %>
      <%= form.text_field :place, placeholder: "Tokyo / Online / Community Lab" %>
    </div>

    <div class="field">
      <%= form.label :publication_status, "公開状態" %>
      <%= form.select :publication_status, EncounterCase::PUBLICATION_STATUSES.map { |value| [ publication_status_label(value), value ] } %>
    </div>

    <div class="field">
      <%= form.label :published_at, "公開日時" %>
      <%= form.datetime_local_field :published_at %>
    </div>

    <div class="field">
      <%= form.label :tag_list, "事例タグ" %>
      <%= form.text_field :tag_list, value: @tag_list, placeholder: "mentorship, collaboration, civic-tech", data: { tag_catalog_target: "input", action: "input->tag-catalog#refresh" } %>
      <p class="field-hint">分野タグもここへ入れられます。下の標準分野カタログからクリック追加できます。</p>
    </div>

    <%= render "shared/representative_field_catalog" %>

    <div class="field">
      <%= form.label :participant_names, "参加人物" %>
      <%= form.text_field :participant_names, value: @participant_names, placeholder: "Ada Lovelace, Charles Babbage" %>
      <p class="field-hint">カンマ区切りで入力します。未登録人物は下書きで自動作成されます。</p>
    </div>

    <div class="field">
      <%= form.label :participant_role, "参加ロール" %>
      <%= form.text_field :participant_role, value: @participant_role, placeholder: "participant / mentor / connector" %>
    </div>

    <div class="field">
      <%= form.label :outcome_category, "結果カテゴリ" %>
      <%= form.text_field :outcome_category, value: @outcome_category, placeholder: "innovation / learning / conflict / community" %>
    </div>

    <div class="field">
      <%= form.label :outcome_direction, "結果の向き" %>
      <%= form.select :outcome_direction, CaseOutcome::OUTCOME_DIRECTIONS.map { |value| [ outcome_direction_label(value), value ] }, { selected: @outcome_direction } %>
    </div>

    <div class="field">
      <%= form.label :outcome_description, "何が起きたか" %>
      <%= form.text_area :outcome_description, value: @outcome_description, rows: 4, placeholder: "前進、停滞、失敗、摩擦を含めて、出会いの結果を書きます。" %>
    </div>

    <div class="field">
      <%= form.label :impact_scope, "影響範囲" %>
      <%= form.text_field :impact_scope, value: @impact_scope, placeholder: "individual / team / field / community" %>
    </div>

    <div class="field">
      <%= form.label :evidence_level, "根拠レベル" %>
      <%= form.select :evidence_level, CaseOutcome::EVIDENCE_LEVELS.map { |value| [ evidence_level_label(value), value ] }, { include_blank: "未設定", selected: @evidence_level } %>
    </div>

    <div class="field">
      <%= form.label :insight_type, "示唆カテゴリ" %>
      <%= form.select :insight_type, CaseInsight::INSIGHT_TYPES.map { |value| [ insight_type_label(value), value ] }, { selected: @insight_type } %>
    </div>

    <div class="field">
      <%= form.label :insight_description, "学び・要因・阻害要因" %>
      <%= form.text_area :insight_description, value: @insight_description, rows: 4, placeholder: "前進を支えたこと、失敗を招いたこと、次に残す教訓を書きます。" %>
    </div>

    <div class="field">
      <%= form.label :application_note, "次にどう活かすか" %>
      <%= form.text_area :application_note, value: @application_note, rows: 3, placeholder: "再現、回避、改善のヒントを書きます。" %>
    </div>

    <div class="field">
      <%= form.label :source_title, "出典タイトル" %>
      <%= form.text_field :source_title, value: @source_title, placeholder: "Interview / Article / Report" %>
    </div>

    <div class="field">
      <%= form.label :source_url, "出典URL" %>
      <%= form.url_field :source_url, value: @source_url, placeholder: "https://example.com/source" %>
    </div>

    <div class="field">
      <%= form.label :source_type, "出典種別" %>
      <%= form.text_field :source_type, value: @source_type, placeholder: "article / interview / report" %>
    </div>

    <div class="field">
      <%= form.label :source_published_on, "出典公開日" %>
      <%= form.date_field :source_published_on, value: @source_published_on %>
    </div>

    <%= form.submit(@encounter_case.new_record? ? "事例を作成" : "事例を更新", class: "primary-button") %>
  <% end %>
</section>
