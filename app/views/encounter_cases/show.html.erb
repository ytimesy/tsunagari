<% content_for :title, @encounter_case.title %>

<section class="profile-hero">
  <div class="profile-badge">
    <p class="ribbon-label">Encounter Case</p>
    <h1><%= @encounter_case.title %></h1>
    <p class="meta"><%= @encounter_case.happened_on || "時期未設定" %> / <%= @encounter_case.place.presence || "場所未設定" %></p>
    <div class="status-petal"><%= publication_status_label(@encounter_case.publication_status) %></div>
  </div>

  <%= link_to "編集", edit_encounter_case_path(@encounter_case), class: "primary-link" %>
</section>

<section class="dashboard-grid">
  <article class="panel soft-panel">
    <p class="eyebrow">Case Summary</p>
    <h2>事例概要</h2>
    <%= simple_format(@encounter_case.summary.presence || "要約未設定") %>
    <p><strong>背景:</strong></p>
    <%= simple_format(@encounter_case.background.presence || "背景未設定") %>

    <div class="tag-cloud">
      <% if @encounter_case.tags.any? %>
        <% @encounter_case.tags.order(:name).each do |tag| %>
          <span class="tag-pill"><%= tag.name %></span>
        <% end %>
      <% else %>
        <span class="tag-pill muted">タグ未設定</span>
      <% end %>
    </div>
  </article>

  <article class="panel soft-panel">
    <p class="eyebrow">Participants</p>
    <h2>関わった人物</h2>
    <% if @encounter_case.case_participants.any? %>
      <ul class="stack-list soft-list">
        <% @encounter_case.case_participants.includes(:person).each do |participant| %>
          <li>
            <strong><%= link_to participant.person.display_name, person_path(participant.person) %></strong>
            <span class="meta"><%= participant.participation_role %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-note">参加人物はまだ設定されていません。</p>
    <% end %>
  </article>
</section>

<section class="dashboard-grid">
  <article class="panel soft-panel">
    <p class="eyebrow">Outcomes</p>
    <h2>何が起き、どう変化したか</h2>
    <% if @encounter_case.case_outcomes.any? %>
      <ul class="stack-list note-list">
        <% @encounter_case.case_outcomes.each do |outcome| %>
          <li class="timeline-card">
            <strong><%= outcome.category %></strong>
            <span class="tag-pill"><%= outcome_direction_label(outcome.outcome_direction) %></span>
            <span class="meta"><%= outcome.impact_scope.presence || "影響範囲未設定" %> / <%= evidence_level_label(outcome.evidence_level.presence || "reported") %></span>
            <div><%= simple_format(outcome.description) %></div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-note">結果はまだ整理されていません。</p>
    <% end %>
  </article>

  <article class="panel soft-panel">
    <p class="eyebrow">Insights</p>
    <h2>学びと示唆</h2>
    <% if @encounter_case.case_insights.any? %>
      <ul class="stack-list note-list">
        <% @encounter_case.case_insights.each do |insight| %>
          <li class="timeline-card">
            <strong><%= insight_type_label(insight.insight_type) %></strong>
            <div><%= simple_format(insight.description) %></div>
            <% if insight.application_note.present? %>
              <p class="meta">次に活かす視点: <%= insight.application_note %></p>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-note">学びや示唆はまだ整理されていません。</p>
    <% end %>
  </article>
</section>

<section class="dashboard-grid">
  <article class="panel soft-panel">
    <p class="eyebrow">Sources</p>
    <h2>出典</h2>
    <% if @encounter_case.sources.any? %>
      <ul class="stack-list soft-list">
        <% @encounter_case.sources.each do |source| %>
          <li>
            <strong><%= link_to source.title, source.url, target: "_blank", rel: "noreferrer" %></strong>
            <span class="meta"><%= source.source_type.presence || "種別未設定" %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-note">出典はまだ設定されていません。</p>
    <% end %>
  </article>

  <article class="panel soft-panel">
    <p class="eyebrow">Wiki Notes</p>
    <h2>追記メモ</h2>

    <%= form_with url: research_notes_path do |form| %>
      <%= form.hidden_field :encounter_case_id, value: @encounter_case.id, name: "research_note[encounter_case_id]" %>

      <div class="field">
        <%= form.label :note_kind, "メモ種別" %>
        <%= form.select :note_kind, ResearchNote::NOTE_KINDS.map { |value| [ value.humanize, value ] }, {}, name: "research_note[note_kind]" %>
      </div>

      <div class="field">
        <%= form.label :body, "内容" %>
        <%= form.text_area :body, rows: 4, required: true, name: "research_note[body]" %>
      </div>

      <%= form.submit "メモを残す", class: "primary-button" %>
    <% end %>

    <% if @research_notes.any? %>
      <ul class="stack-list note-list">
        <% @research_notes.each do |note| %>
          <li class="timeline-card">
            <strong><%= note.note_kind.humanize %></strong>
            <div><%= simple_format(note.body) %></div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-note">まだ追記メモはありません。補足や異論、追加情報を残してください。</p>
    <% end %>
  </article>
</section>
