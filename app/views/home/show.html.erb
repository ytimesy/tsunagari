<% content_for :title, "Tsunagari" %>

<section class="hero-stage">
  <article class="hero-card hero-copy">
    <p class="ribbon-label">First Principle</p>
    <h1 class="hero-title">出会いから、<br>より良くなる。</h1>
    <p class="lede">
      Tsunagari は、良い出会いの構造を記録し、その再現性を高めることで、
      人と社会の前進を支えるための情報サイトです。
    </p>

    <div class="hero-actions">
      <% if user_signed_in? %>
        <%= link_to "新規事例を作る", new_encounter_case_path, class: "primary-link" %>
        <%= link_to "人物録を見る", people_path, class: "secondary-link" %>
      <% else %>
        <%= link_to "出会い事例を見る", encounter_cases_path, class: "primary-link" %>
        <%= link_to "編集ログイン", sign_in_path, class: "secondary-link" %>
      <% end %>
    </div>

    <% unless user_signed_in? %>
      <p class="meta">編集参加する場合は <%= link_to "編集メンバー登録", sign_up_path %> から始められます。</p>
    <% end %>

    <div class="feature-strip">
      <span class="feature-pill">encounter</span>
      <span class="feature-pill">outcome</span>
      <span class="feature-pill">reproducibility</span>
    </div>
  </article>

  <aside class="hero-card mascot-panel">
    <div class="mascot-orb">
      <div class="mascot-core">ROOT</div>
    </div>
    <p class="mascot-name">Human Progress Through Encounters</p>
    <p class="mascot-copy">
      ただ成功談を並べるのではなく、その出会いが何を前進させ、
      どこでつまずき、次にどう活かせるのかまで読める形に整えていきます。
    </p>
    <ul class="speech-list">
      <li>人物録を辿る</li>
      <li>前進と失敗の条件を探る</li>
      <li>再現と回避のヒントを残す</li>
    </ul>
  </aside>
</section>

<% if user_signed_in? %>
  <section class="dashboard-grid">
    <article class="panel soft-panel">
      <p class="eyebrow">Editorial Cases</p>
      <h2>最近編集した事例</h2>
      <% if @recent_cases.any? %>
        <ul class="stack-list soft-list">
          <% @recent_cases.each do |encounter_case| %>
            <li>
              <strong><%= link_to encounter_case.title, encounter_case_path(encounter_case) %></strong>
              <span class="meta"><%= publication_status_label(encounter_case.publication_status) %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-note">まだ事例はありません。最初の出会い事例を作るところから始めましょう。</p>
      <% end %>
    </article>

    <article class="panel soft-panel">
      <p class="eyebrow">Editorial Notes</p>
      <h2>最近の編集メモ</h2>
      <% if @recent_notes.any? %>
        <ul class="stack-list soft-list">
          <% @recent_notes.each do |note| %>
            <li>
              <strong>
                <% if note.person.present? %>
                  <%= link_to note.person.display_name, person_path(note.person) %>
                <% elsif note.encounter_case.present? %>
                  <%= link_to note.encounter_case.title, encounter_case_path(note.encounter_case) %>
                <% end %>
              </strong>
              <span class="meta"><%= truncate(note.body, length: 70) %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-note">編集メモはまだありません。人物や事例に仮説を書き始めると、調査の軸が定まります。</p>
      <% end %>
    </article>
  </section>
<% else %>
  <section class="dashboard-grid">
    <article class="panel soft-panel">
      <p class="eyebrow">Published People</p>
      <h2><%= @published_people_count %> 人物</h2>
      <p>公開中の人物録から、どんな人がどんな変化の起点になっているかを辿れます。</p>
    </article>
    <article class="panel soft-panel">
      <p class="eyebrow">Published Cases</p>
      <h2><%= @published_case_count %> 事例</h2>
      <p>出会い事例から、何が前進し、どこでつまずき、何を学べるのかを読めます。</p>
    </article>
    <article class="panel soft-panel">
      <p class="eyebrow">How To Use</p>
      <h2>次の一歩に活かす</h2>
      <p>人物、結果、学びを読み比べて、自分の次の挑戦に転用できるヒントを持ち帰れます。</p>
    </article>
  </section>

  <section class="results-grid">
    <% @featured_cases.each do |encounter_case| %>
      <article class="panel result-card">
        <p class="eyebrow">Featured Case</p>
        <h2><%= link_to encounter_case.title, encounter_case_path(encounter_case) %></h2>
        <p class="meta"><%= encounter_case.happened_on || "時期未設定" %> / <%= encounter_case.place.presence || "場所未設定" %></p>
        <% if (primary_outcome = encounter_case.case_outcomes.first).present? %>
          <p class="meta"><%= outcome_direction_label(primary_outcome.outcome_direction) %> / <%= primary_outcome.category %></p>
        <% end %>
        <p><%= truncate(encounter_case.summary.presence || encounter_case.background.presence || "概要未設定", length: 120) %></p>
      </article>
    <% end %>
  </section>
<% end %>
