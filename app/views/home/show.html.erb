<% content_for :title, "Tsunagari" %>

<section class="hero-stage">
  <article class="hero-card hero-copy">
    <p class="ribbon-label">First Principle</p>
    <h1 class="hero-title">出会いから、<br>より良くなる。</h1>
    <p class="lede">
      Tsunagari は、良い出会いの構造を記録し、その再現性を高めることで、
      人と社会の前進を支えるための情報サイトです。
    </p>

    <div class="hero-actions">
      <% if user_signed_in? %>
        <%= link_to "編集プロフィールへ", profile_path, class: "primary-link" %>
        <%= link_to "人物録を見る", users_path, class: "secondary-link" %>
      <% else %>
        <%= link_to "人物録を見る", users_path, class: "primary-link" %>
        <%= link_to "編集ログイン", sign_in_path, class: "secondary-link" %>
      <% end %>
    </div>

    <% unless user_signed_in? %>
      <p class="meta">編集参加する場合は <%= link_to "編集メンバー登録", sign_up_path %> から始められます。</p>
    <% end %>

    <div class="feature-strip">
      <span class="feature-pill">encounter</span>
      <span class="feature-pill">outcome</span>
      <span class="feature-pill">reproducibility</span>
    </div>
  </article>

  <aside class="hero-card mascot-panel">
    <div class="mascot-orb">
      <div class="mascot-core">ROOT</div>
    </div>
    <p class="mascot-name">Human Progress Through Encounters</p>
    <p class="mascot-copy">
      ただ出会った事実を並べるのではなく、その出会いが何を前進させたのか、
      なぜ起きたのか、次にどう活かせるのかまで読める形に整えていきます。
    </p>
    <ul class="speech-list">
      <li>人物録を辿る</li>
      <li>出会いの条件を探る</li>
      <li>再現性のヒントを残す</li>
    </ul>
  </aside>
</section>

<% if user_signed_in? %>
  <section class="dashboard-grid">
    <article class="panel soft-panel">
      <p class="eyebrow">Watchlist</p>
      <h2>最近注目した人物</h2>
      <% if @favorite_users.any? %>
        <ul class="stack-list soft-list">
          <% @favorite_users.each do |user| %>
            <li>
              <strong><%= link_to user.profile.display_name, user_path(user) %></strong>
              <span class="meta"><%= user.profile.organization.presence || "所属未設定" %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-note">注目人物はまだありません。良い出会いの起点になりそうな人物を見つけたら、ここに残していきましょう。</p>
      <% end %>
    </article>

    <article class="panel soft-panel">
      <p class="eyebrow">Editorial Notes</p>
      <h2>最近の取材メモ</h2>
      <% if @recent_notes.any? %>
        <ul class="stack-list soft-list">
          <% @recent_notes.each do |note| %>
            <li>
              <strong><%= link_to note.subject_user.profile.display_name, user_path(note.subject_user) %></strong>
              <span class="meta"><%= truncate(note.note, length: 70) %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-note">取材メモはまだありません。どんな出会いが何を前進させ、なぜそうなったのかを残しておくと、事例の質が上がります。</p>
      <% end %>
    </article>
  </section>
<% else %>
  <section class="dashboard-grid">
    <article class="panel soft-panel">
      <p class="eyebrow">Step 01</p>
      <h2>良い出会いの入口を知る</h2>
      <p>公開中の人物票から、どんな人がどんな前進の起点になっているかを掴めます。</p>
    </article>
    <article class="panel soft-panel">
      <p class="eyebrow">Step 02</p>
      <h2>条件と文脈を読む</h2>
      <p>名前、所属、役割、タグから検索して、どんな条件で前向きな出会いが起きたのかを横断的に辿れます。</p>
    </article>
    <article class="panel soft-panel">
      <p class="eyebrow">Step 03</p>
      <h2>次の一歩に活かす</h2>
      <p>人物単体ではなく、その出会いで何が良くなったのかを読み、自分や社会の次の前進に活かす土台にします。</p>
    </article>
  </section>
<% end %>
