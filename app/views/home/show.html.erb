<% content_for :title, 'Tsunagari' %>

<section class="hero-stage atlas-stage impact-stage">
  <article class="hero-card hero-copy atlas-hero-copy impact-hero-copy">
    <p class="ribbon-label">First Principle</p>
    <h1 class="hero-title">人物から、<br>関係を読む。</h1>
    <p class="lede">
      Tsunagari は、人物・関係・補足情報を整理して、
      誰が誰に効くのかを読み取りやすくするための情報サイトです。
    </p>

    <div class="hero-actions">
      <% if can_edit_content? %>
        <%= link_to '新規人物を作る', new_person_path, class: 'primary-link' %>
      <% else %>
        <%= link_to '全体関係マップを見る', graph_people_path, class: 'primary-link' %>
      <% end %>
      <%= link_to '人物録を見る', people_path, class: 'secondary-link' %>
    </div>

    <p class="meta">
      <% if TsunagariFeatureFlags.strict_public_visibility? %>
        Tsunagari は wiki 方式です。公開中の人物を誰でも閲覧でき、編集や追記はログイン後に行います。
      <% else %>
        Tsunagari は wiki 方式です。アーカイブ前の人物を誰でも閲覧でき、編集や追記はログイン後に行います。
      <% end %>
    </p>

    <div class="feature-strip feature-strip--impact">
      <span class="feature-pill">people</span>
      <span class="feature-pill">relations</span>
      <span class="feature-pill">insight</span>
    </div>

    <div class="compact-stats impact-stats">
      <span class="status-petal impact-petal"><strong><%= @people_count %></strong> 人物</span>
      <span class="status-petal impact-petal"><strong><%= @quality_people_count %></strong> 活用視点あり</span>
      <span class="status-petal impact-petal"><strong><%= @latest_people.count %></strong> 更新</span>
    </div>
  </article>

  <aside class="hero-card mascot-panel atlas-hero-aside impact-hero-aside">
    <div class="mascot-orb">
      <div class="mascot-core">ROOT</div>
    </div>
    <p class="mascot-name">Human Signals Through People</p>
    <p class="mascot-copy">
      ただプロフィールを並べるのではなく、その人物が何に役立ち、
      どの関係の中で効くのかまで読める形に整えていきます。
    </p>
    <ul class="speech-list">
      <li>人物録を辿る</li>
      <li>関係の理由を探る</li>
      <li>次に見るべき人物を残す</li>
    </ul>
  </aside>
</section>

<section class="dashboard-grid atlas-summary-grid">
  <article class="panel soft-panel atlas-stat-panel">
    <p class="eyebrow">Wiki Scope</p>
    <h2><%= @people_count %> 人物</h2>
    <p>
      <% if TsunagariFeatureFlags.strict_public_visibility? %>
        人物録は公開中の人物だけを一般公開し、下書きやレビュー中の情報は公開前の整理用として扱います。
      <% else %>
        人物録はアーカイブ前の人物を一般公開し、整理中の情報もあとから補いながら育てていきます。
      <% end %>
    </p>
  </article>
  <article class="panel soft-panel atlas-stat-panel">
    <p class="eyebrow">Map Scope</p>
    <h2>全体関係マップ</h2>
    <p>
      <% if TsunagariFeatureFlags.strict_public_visibility? %>
        全体関係マップは公開中の人物を土台に組み立て、人物群どうしの接点を俯瞰できるようにしています。
      <% else %>
        全体関係マップはアーカイブ前の人物を土台に組み立て、整理中の人物も含めて関係を育てられる構成です。
      <% end %>
    </p>
  </article>
  <article class="panel soft-panel atlas-stat-panel">
    <p class="eyebrow">How To Use</p>
    <h2><%= can_edit_content? ? 'その場で加筆する' : '公開ページを辿る' %></h2>
    <p><%= can_edit_content? ? '気づいた情報があれば、そのまま人物を編集し、追記メモを残してください。' : '人物録と全体関係マップを往復しながら、気になる関係を辿ってください。' %></p>
  </article>
</section>

<% if can_edit_content? %>
  <section class="dashboard-grid">
    <article class="panel soft-panel">
      <p class="eyebrow">Publication Status</p>
      <h2>公開状態サマリー</h2>
      <p class="meta">人物録の状態別件数です。クリックすると該当状態だけに絞り込めます。</p>
      <div class="status-summary-list">
        <% Person::PUBLICATION_STATUSES.each do |status| %>
          <%= link_to people_path(publication_status: status), class: "status-summary-link" do %>
            <span><%= publication_status_label(status) %></span>
            <strong><%= @people_status_counts.fetch(status, 0) %> 件</strong>
          <% end %>
        <% end %>
      </div>
    </article>

    <article class="panel soft-panel">
      <p class="eyebrow">Insight Coverage</p>
      <h2>活用視点あり <%= @quality_people_count %> 人</h2>
      <p class="meta">役立つ文脈や会う価値が入っている人物数です。情報の質を上げる作業量の目安として見ます。</p>
    </article>

    <article class="panel soft-panel">
      <p class="eyebrow">Public Mode</p>
      <h2><%= TsunagariFeatureFlags.strict_public_visibility? ? '公開中のみを公開' : 'アーカイブ以外を公開' %></h2>
      <p><%= TsunagariFeatureFlags.strict_public_visibility? ? '仕様どおり、公開中のデータだけが一般公開されています。' : '現在は暫定運用として、アーカイブ以外のデータが一般公開されています。' %></p>
    </article>
  </section>
<% end %>

<section class="dashboard-grid">
  <article class="panel soft-panel membership-card membership-card--accent">
    <p class="eyebrow">Insight</p>
    <h2>情報の質で読む</h2>
    <p>件数ではなく、この人物が何に役立つか、誰と組み合わせると価値が出るか、次に誰を追うべきかを読めることを前面に出します。</p>
    <div class="tag-cloud">
      <span class="tag-pill">活用視点</span>
      <span class="tag-pill">仮説の人物像</span>
      <span class="tag-pill">関係の理由</span>
    </div>
    <div class="hero-actions">
      <%= link_to 'Insightを見る', insight_membership_path, class: 'primary-link' %>
      <%= link_to '人物録を見る', people_path, class: 'secondary-link' %>
    </div>
  </article>

  <article class="panel soft-panel">
    <p class="eyebrow">Latest People</p>
    <h2>最近更新された人物</h2>
    <% if @latest_people.any? %>
      <ul class="stack-list soft-list">
        <% @latest_people.each do |person| %>
          <li>
            <strong><%= link_to person.display_name, person_destination_path(person) %></strong>
            <% if can_edit_content? %>
              <span class="meta"><%= publication_status_label(person.publication_status) %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-note">まだ人物はありません。最初の人物を登録するところから始めましょう。</p>
    <% end %>
  </article>

  <article class="panel soft-panel">
    <p class="eyebrow">Latest Notes</p>
    <h2>最近の追記メモ</h2>
    <% if can_edit_content? %>
      <% if @latest_notes.any? %>
        <ul class="stack-list soft-list">
          <% @latest_notes.each do |note| %>
            <li>
              <strong><%= link_to note.person.display_name, person_destination_path(note.person) %></strong>
              <span class="meta"><%= truncate(note.body, length: 70) %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-note">まだ追記メモはありません。人物に仮説や補足を書き始めてください。</p>
      <% end %>
    <% else %>
      <p class="empty-note">追記メモの閲覧と記入は、編集者ログイン後に利用できます。</p>
    <% end %>
  </article>
</section>
