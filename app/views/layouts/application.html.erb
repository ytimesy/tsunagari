<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tsunagari" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="page-glow" aria-hidden="true"></div>
    <header class="site-header">
      <div class="shell nav-row">
        <%= link_to root_path, class: "brand" do %>
          <span class="brand-mark">Tsunagari</span>
          <span class="brand-sub">better through encounters</span>
        <% end %>

        <nav class="nav-links">
          <% if user_signed_in? %>
            <span class="nav-user"><%= current_user.profile.display_name %></span>
            <%= link_to "編集プロフィール", profile_path %>
            <%= link_to "人物録", users_path %>
            <%= link_to "注目人物", favorites_path %>
            <%= link_to "ログアウト", sign_out_path, data: { turbo_method: :delete }, class: "ghost-button" %>
          <% else %>
            <%= link_to "人物録", users_path %>
            <%= link_to "編集ログイン", sign_in_path %>
            <%= link_to "編集メンバー登録", sign_up_path, class: "primary-link" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="shell main-content">
      <% flash.each do |type, message| %>
        <div class="flash <%= type %>"><%= message %></div>
      <% end %>

      <div class="page-stack">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
