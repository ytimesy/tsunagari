<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || 'Tsunagari' %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="<%= manifest_href %>">
    <link rel="icon" href="<%= icon_png_href %>" type="image/png">
    <link rel="icon" href="<%= icon_svg_href %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= icon_png_href %>">
    <%= stylesheet_link_tag 'application', 'data-turbo-track': 'reload' %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="page-glow" aria-hidden="true"></div>
    <header class="site-header">
      <div class="shell nav-row">
        <%= link_to root_path, class: 'brand brand--impact' do %>
          <span class="brand-stamp">TSUNAGARI</span>
          <span class="brand-mark">出会いの情報圧を上げる</span>
          <span class="brand-sub">human progress through encounters</span>
        <% end %>

        <nav class="nav-links nav-links--impact">
          <%= link_to 'トップ', root_path %>
          <%= link_to '人物録', people_path %>
          <%= link_to '全体関係マップ', graph_people_path %>
          <%= link_to '出会い事例', encounter_cases_path %>
          <%= link_to "保存リスト#{saved_people_count.positive? ? " (#{saved_people_count})" : ''}", saved_people_path %>
          <% if can_edit_content? %>
            <span class="nav-user"><%= "#{current_user.email} / #{role_label(current_user.role)}" %></span>
            <%= link_to '新規人物', new_person_path %>
            <%= link_to '新規事例', new_encounter_case_path, class: 'primary-link' %>
            <%= link_to 'ログアウト', logout_path, data: { turbo_method: :delete } %>
          <% else %>
            <%= link_to 'ログイン', login_path, class: 'primary-link' %>
          <% end %>
        </nav>
      </div>
      <div class="signal-strip">
        <div class="shell signal-strip-inner">
          <span class="signal-label">LIVE SIGNAL</span>
          <span class="signal-copy">人物・出会い・関係を、早く深く追うための記録面</span>
          <div class="signal-links">
            <%= link_to '人物録を見る', people_path %>
            <%= link_to '関係マップを見る', graph_people_path %>
            <%= link_to '事例を追う', encounter_cases_path %>
          </div>
        </div>
      </div>
    </header>

    <main class="shell main-content">
      <% flash.each do |type, message| %>
        <div class="flash <%= type %>"><%= message %></div>
      <% end %>

      <div class="page-stack">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
