<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || 'Tsunagari' %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="<%= manifest_href %>">
    <link rel="icon" href="<%= icon_png_href %>" type="image/png">
    <link rel="icon" href="<%= icon_svg_href %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= icon_png_href %>">
    <%= stylesheet_link_tag 'application', 'data-turbo-track': 'reload' %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="page-glow" aria-hidden="true"></div>
    <header class="site-header">
      <div class="shell nav-row">
        <%= link_to root_path, class: 'brand' do %>
          <span class="brand-mark">Tsunagari</span>
          <span class="brand-sub">human progress through encounters</span>
        <% end %>

        <nav class="nav-links">
          <%= link_to 'トップ', root_path %>
          <%= link_to '人物録', people_path %>
          <%= link_to '全体関係マップ', graph_people_path %>
          <%= link_to '出会い事例', encounter_cases_path %>
          <%= link_to(can_edit_content? ? '依頼一覧' : '人物リストを依頼', can_edit_content? ? list_requests_path : new_list_request_path) %>
          <% if can_edit_content? %>
            <span class="meta"><%= "#{current_user.email} / #{role_label(current_user.role)}" %></span>
            <%= link_to '新規人物', new_person_path %>
            <%= link_to '新規事例', new_encounter_case_path, class: 'primary-link' %>
            <%= link_to 'ログアウト', logout_path, data: { turbo_method: :delete } %>
          <% else %>
            <%= link_to 'ログイン', login_path, class: 'primary-link' %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="shell main-content">
      <% flash.each do |type, message| %>
        <div class="flash <%= type %>"><%= message %></div>
      <% end %>

      <div class="page-stack">
        <%= yield %>
      </div>
    </main>
  </body>
</html>
