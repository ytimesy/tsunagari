<% content_for :title, '人物リスト作成依頼' %>

<section class="page-header dreamy-header">
  <div>
    <p class="ribbon-label">Request A List</p>
    <h1>人物リスト作成依頼</h1>
    <p class="lede compact">テーマに合わせて、会う価値のある人物候補を手作業で整理して納品する入口です。まずは価格を固定した小さな商品から始めます。</p>
  </div>
  <div class="hero-actions">
    <%= link_to 'トップへ戻る', root_path, class: 'secondary-link' %>
    <% if can_edit_content? %>
      <%= link_to '依頼一覧を見る', list_requests_path, class: 'primary-link' %>
    <% end %>
  </div>
</section>

<section class="dashboard-grid request-offer-grid">
  <% ListRequest::PACKAGES.each do |package_key, package| %>
    <article class="panel soft-panel request-offer-card<%= ' is-selected' if @selected_package_key == package_key %>">
      <p class="eyebrow">Offer</p>
      <h2><%= package[:label] %></h2>
      <p class="offer-price"><%= package[:price_label] %></p>
      <p><%= package[:pitch] %></p>
      <ul class="stack-list soft-list compact-list">
        <% package[:features].each do |feature| %>
          <li><%= feature %></li>
        <% end %>
      </ul>
      <div class="hero-actions">
        <%= link_to 'このプランで依頼する', new_list_request_path(package: package_key), class: (@selected_package_key == package_key ? 'primary-link' : 'secondary-link') %>
      </div>
    </article>
  <% end %>
</section>

<% if @submitted_list_request.present? %>
  <section class="panel soft-panel request-confirmation-panel">
    <p class="eyebrow">Next Step</p>
    <h2>依頼を受け付けました</h2>
    <p class="meta"><%= @submitted_list_request.package_label %> / <%= @submitted_list_request.package_price_label %> / <%= @submitted_list_request.requested_count %> 人</p>
    <p>このまま支払いまで進めるか、まず内容確認の連絡を待つかを選べます。</p>
    <div class="tag-cloud">
      <span class="tag-pill"><%= @submitted_list_request.request_theme %></span>
      <span class="tag-pill muted"><%= list_request_payment_status_label(@submitted_list_request.payment_status) %></span>
    </div>
    <div class="hero-actions">
      <% if list_request_payment_ready?(@submitted_list_request) %>
        <%= link_to '支払いへ進む', list_request_payment_url(@submitted_list_request), class: 'primary-link', target: '_blank', rel: 'noopener' %>
      <% else %>
        <span class="meta">このプランの支払いリンクはまだ未設定です。先に連絡で案内します。</span>
      <% end %>
      <%= link_to '別の依頼を作る', new_list_request_path(package: @submitted_list_request.package_key), class: 'secondary-link' %>
    </div>
  </section>
<% end %>

<section class="dashboard-grid">
  <article class="panel soft-panel">
    <p class="eyebrow">What You Can Ask</p>
    <h2>こんな依頼に向いています</h2>
    <ul class="stack-list soft-list">
      <li><strong>登壇候補:</strong> 特定テーマで話せる人を10〜20人</li>
      <li><strong>取材候補:</strong> 取材文脈に合う人を短い理由付きで</li>
      <li><strong>共同研究候補:</strong> 研究テーマに近い人物を整理</li>
      <li><strong>紹介先候補:</strong> 相談向き、連携向きの人物を絞る</li>
    </ul>
  </article>

  <article class="panel soft-panel">
    <p class="eyebrow">Delivery</p>
    <h2>納品イメージ</h2>
    <p>まずは人物候補の一覧と、一言理由をまとめた納品を想定しています。要望に応じて件数や形式を調整します。</p>
    <div class="tag-cloud">
      <span class="tag-pill">人物候補</span>
      <span class="tag-pill">一言理由</span>
      <span class="tag-pill">参考URL</span>
      <span class="tag-pill">用途別提案</span>
    </div>
  </article>
</section>

<section class="form-panel cute-frame">
  <p class="ribbon-label">Request Form</p>
  <h2>依頼内容を送る</h2>

  <% if @list_request.errors.any? %>
    <div class="error-summary">
      <p>入力内容を確認してください。</p>
      <ul>
        <% @list_request.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @list_request, class: 'page-stack' do |form| %>
    <div class="field">
      <%= form.label :package_key, 'プラン' %>
      <div class="request-package-options">
        <% ListRequest::PACKAGES.each do |package_key, package| %>
          <label class="request-package-option<%= ' is-selected' if @list_request.package_key == package_key %>">
            <%= form.radio_button :package_key, package_key %>
            <span>
              <strong><%= package[:label] %></strong>
              <small><%= package[:price_label] %> / <%= package[:requested_count] %> 人目安</small>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <div class="field">
      <%= form.label :requester_name, 'お名前' %>
      <%= form.text_field :requester_name, required: true, placeholder: '山田 太郎' %>
    </div>

    <div class="field">
      <%= form.label :requester_email, '連絡先メール' %>
      <%= form.email_field :requester_email, required: true, placeholder: 'you@example.com' %>
    </div>

    <div class="field">
      <%= form.label :request_theme, '探したいテーマ' %>
      <%= form.text_field :request_theme, required: true, placeholder: 'AI領域の登壇候補 / 教育×福祉のキーパーソン' %>
    </div>

    <div class="field">
      <%= form.label :request_purpose, '用途' %>
      <%= form.text_area :request_purpose, rows: 4, placeholder: 'イベント登壇候補を探したい、取材候補を整理したい、共同研究の相談先を見つけたい、など' %>
    </div>

    <div class="dashboard-grid request-grid request-grid--tight">
      <div class="field">
        <%= form.label :requested_count, '希望人数' %>
        <%= form.number_field :requested_count, min: 1, max: 100, required: true %>
      </div>

      <div class="field">
        <%= form.label :delivery_format, '納品形式の希望' %>
        <%= form.select :delivery_format, options_for_select(ListRequest::DELIVERY_FORMATS, @list_request.delivery_format), include_blank: '選んでください' %>
      </div>

      <div class="field">
        <%= form.label :budget_range, '予算感' %>
        <%= form.select :budget_range, options_for_select(ListRequest::BUDGET_RANGES, @list_request.budget_range), include_blank: '選んでください' %>
      </div>

      <div class="field">
        <%= form.label :deadline_preference, '納期感' %>
        <%= form.select :deadline_preference, options_for_select(ListRequest::DEADLINE_PREFERENCES, @list_request.deadline_preference), include_blank: '選んでください' %>
      </div>
    </div>

    <div class="field">
      <%= form.label :note, '補足' %>
      <%= form.text_area :note, rows: 4, placeholder: '優先したい条件、除外したい条件、参考にしてほしい候補など' %>
    </div>

    <div class="hero-actions">
      <%= form.submit '依頼を送る', class: 'primary-button' %>
      <span class="meta">送信後、そのまま支払いに進むか、先に内容確認の連絡を待てます。</span>
    </div>
  <% end %>
</section>
