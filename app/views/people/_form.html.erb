<section class="form-panel cute-frame">
  <p class="ribbon-label">Person Record</p>
  <h1><%= @person.new_record? ? "人物を作成" : "人物を編集" %></h1>

  <% if @person.errors.any? %>
    <div class="error-summary">
      <p>入力内容を確認してください。</p>
      <ul>
        <% @person.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @person do |form| %>
    <div class="field">
      <%= form.label :display_name, "人物名" %>
      <%= form.text_field :display_name, required: true, placeholder: "Ada Lovelace / 佐藤太郎" %>
    </div>

    <div class="field">
      <%= form.label :summary, "要約（ローカル補足）" %>
      <%= form.text_area :summary, rows: 3, placeholder: "何の文脈で重要な人物かを短くまとめます。" %>
      <p class="field-hint">外部DBの内容をそのまま複製せず、必要な補足だけをローカルに残します。</p>
    </div>

    <div class="field">
      <%= form.label :bio, "本文（ローカル補足）" %>
      <%= form.text_area :bio, rows: 8, placeholder: "人物の背景、取り組み、強み、出会いの起点になりそうな要素を書きます。" %>
    </div>

    <div class="field">
      <%= form.label :publication_status, "公開状態" %>
      <%= form.select :publication_status, Person::PUBLICATION_STATUSES.map { |value| [ publication_status_label(value), value ] } %>
    </div>

    <div class="field">
      <%= form.label :published_at, "公開日時" %>
      <%= form.datetime_local_field :published_at %>
    </div>

    <div class="field">
      <%= form.label :tag_list, "タグ（ローカル補足）" %>
      <%= form.text_field :tag_list, value: @tag_list, placeholder: "research, community, mentorship" %>
      <p class="field-hint">カンマ区切りで入力します。外部DBのタグではなく、Tsunagari 内で補いたい観点だけを残します。</p>
    </div>

    <div class="field">
      <%= form.label :primary_organization_name, "主な所属名（ローカル補足）" %>
      <%= form.text_field :primary_organization_name, value: @primary_organization_name, placeholder: "OpenAI / Civic Tech Tokyo" %>
    </div>

    <div class="field">
      <%= form.label :primary_organization_category, "所属カテゴリ" %>
      <%= form.text_field :primary_organization_category, value: @primary_organization_category, placeholder: "company / community / university" %>
    </div>

    <div class="field">
      <%= form.label :primary_organization_website_url, "所属URL" %>
      <%= form.url_field :primary_organization_website_url, value: @primary_organization_website_url, placeholder: "https://example.com" %>
    </div>

    <div class="field">
      <%= form.label :primary_affiliation_title, "肩書き" %>
      <%= form.text_field :primary_affiliation_title, value: @primary_affiliation_title, placeholder: "Researcher / Organizer / Mentor" %>
    </div>

    <%= form.submit(@person.new_record? ? "人物を作成" : "人物を更新", class: "primary-button") %>
  <% end %>
</section>
