<% content_for :title, @person.display_name %>
<% deep_insight = deep_insight_access? %>

<section class="profile-hero">
  <div class="profile-badge">
    <p class="ribbon-label">Person</p>
    <h1><%= @person.display_name %></h1>
    <% affiliation = @resolved_person_profile[:affiliations].first %>
    <p class="meta">
      <%= affiliation&.dig(:name).presence || "所属未設定" %>
      <% if affiliation&.dig(:title).present? %>
        / <%= affiliation[:title] %>
      <% end %>
    </p>
    <%= render "shared/record_provenance", source_entries: person_source_entries(@person), edit_histories: @edit_histories %>
  </div>

  <div class="hero-actions">
    <%= link_to "全体関係マップ", graph_people_path, data: { turbo: false }, class: "secondary-link" %>
    <%= link_to "Insight", insight_membership_path, class: "secondary-link" %>
    <% if can_edit_content? %>
      <%= link_to external_people_import_title(target_person: @person), new_person_import_path(q: @person.display_name, person_id: @person.id), class: "secondary-link" %>
      <%= link_to "編集", edit_person_path(@person), class: "primary-link" %>
    <% end %>
  </div>
</section>

<section class="dashboard-grid">
  <article class="panel soft-panel relationship-panel relationship-panel--wide person-insight-panel">
    <p class="eyebrow">Tsunagari Insight</p>
    <h2>この人物の活用視点</h2>
    <p class="meta">外部DBの説明ではなく、Tsunagari が補う判断材料です。</p>

    <% if @person.quality_insight? %>
      <% if deep_insight %>
        <div class="person-insight-grid">
          <article class="person-insight-card">
            <h3>役立つ文脈</h3>
            <%= simple_format(@person.recommended_for.presence || "まだ未設定です。") %>
          </article>

          <article class="person-insight-card">
            <h3>会う価値</h3>
            <%= simple_format(@person.meeting_value.presence || "まだ未設定です。") %>
          </article>

          <article class="person-insight-card">
            <h3>向いている用途</h3>
            <% if @person.fit_modes_list.any? %>
              <div class="tag-cloud">
                <% @person.fit_modes_list.each do |fit_mode| %>
                  <span class="tag-pill person-fit-pill"><%= fit_mode %></span>
                <% end %>
              </div>
            <% else %>
              <p class="empty-note">まだ用途タグは未設定です。</p>
            <% end %>
            <% if @person.last_reviewed_on.present? %>
              <p class="meta person-review-meta"><%= "最終確認日: #{l(@person.last_reviewed_on)}" %></p>
            <% end %>
          </article>

          <article class="person-insight-card">
            <h3>紹介メモ</h3>
            <%= simple_format(@person.introduction_note.presence || "まだ未設定です。") %>
          </article>
        </div>
      <% else %>
        <div class="person-insight-grid person-insight-grid--locked">
          <article class="person-insight-card">
            <h3>役立つ文脈</h3>
            <%= simple_format(truncate(@person.recommended_for.presence || "まだ未設定です。", length: 80)) %>
          </article>

          <article class="person-insight-card insight-locked-card">
            <h3>会う価値</h3>
            <p class="insight-locked-copy">この人物に会う意味づけと、相談しやすい論点は Insight で読めます。</p>
          </article>

          <article class="person-insight-card insight-locked-card">
            <h3>向いている用途</h3>
            <p class="insight-locked-copy"><%= @person.fit_modes_list.any? ? "#{@person.fit_modes_list.first} までは公開中。残りの用途タグは登録後に読めます。" : "用途タグの整理は Insight で読めます。" %></p>
          </article>

          <article class="person-insight-card insight-locked-card">
            <h3>紹介メモ</h3>
            <p class="insight-locked-copy">紹介時の切り口、注意点、相性の良い相手は利用登録後に見られます。</p>
          </article>
        </div>
        <%= render "shared/insight_membership_cta", title: "活用視点の全文は Insight で読めます", copy: "無料では概要だけを見せ、会う価値や紹介メモは利用登録後に表示します。" %>
      <% end %>
    <% else %>
      <p class="empty-note">まだ Tsunagari 独自の活用視点は未設定です。</p>
      <% if can_edit_content? %>
        <div class="hero-actions">
          <%= link_to "活用視点を編集する", edit_person_path(@person), class: "secondary-link" %>
        </div>
      <% end %>
    <% end %>
  </article>
</section>

<section class="dashboard-grid">
  <% persona_sketch = @person_public_estimate[:persona_sketch] || {} %>
  <% persona_visual = persona_sketch[:visual] || {} %>
  <article class="panel soft-panel relationship-panel relationship-panel--wide persona-sketch-panel">
    <p class="eyebrow">Imagined Portrait</p>
    <h2>仮説の人物像</h2>
    <p class="meta"><%= persona_sketch[:notice] %></p>

    <div class="persona-sketch-layout">
      <div class="persona-portrait persona-portrait--<%= persona_visual[:palette] %> persona-portrait--<%= persona_visual[:motif] %>">
        <div class="persona-portrait-core">
          <p class="persona-portrait-kicker">Public Clues</p>
          <p class="persona-portrait-initials"><%= persona_visual[:initials] %></p>
          <p class="persona-portrait-title"><%= persona_sketch[:title] %></p>
        </div>

        <% if persona_visual[:orbit_labels].present? %>
          <div class="persona-portrait-orbits">
            <% persona_visual[:orbit_labels].each do |label| %>
              <span class="persona-portrait-orbit"><%= label %></span>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="persona-sketch-copy">
        <p class="persona-sketch-summary"><%= persona_sketch[:summary] %></p>

        <% if deep_insight %>
          <div class="persona-sketch-grid">
            <article class="persona-sketch-card">
              <h3>仕事の進め方</h3>
              <p class="persona-sketch-label"><%= persona_sketch.dig(:work_style, :label) %></p>
              <p class="person-lens-copy"><%= persona_sketch.dig(:work_style, :reason) %></p>
            </article>

            <article class="persona-sketch-card">
              <h3>関わり方の印象</h3>
              <p class="persona-sketch-label"><%= persona_sketch.dig(:interaction_style, :label) %></p>
              <p class="person-lens-copy"><%= persona_sketch.dig(:interaction_style, :reason) %></p>
            </article>

            <article class="persona-sketch-card">
              <h3>動きやすい場面</h3>
              <p class="persona-sketch-label"><%= persona_sketch.dig(:momentum, :label) %></p>
              <p class="person-lens-copy"><%= persona_sketch.dig(:momentum, :reason) %></p>
            </article>
          </div>
        <% else %>
          <div class="persona-sketch-grid">
            <article class="persona-sketch-card insight-locked-card">
              <h3>仕事の進め方</h3>
              <p class="insight-locked-copy">この人物が深掘り型か、実装型か、翻訳型かの読み解きは登録後に読めます。</p>
            </article>

            <article class="persona-sketch-card insight-locked-card">
              <h3>関わり方の印象</h3>
              <p class="insight-locked-copy">異分野をつなぐか、近い専門圏で動くかの仮説は登録後に読めます。</p>
            </article>

            <article class="persona-sketch-card insight-locked-card">
              <h3>動きやすい場面</h3>
              <p class="insight-locked-copy">どんな場面でこの人物が活きるかの仮説は利用登録後に見られます。</p>
            </article>
          </div>
          <%= render "shared/insight_membership_cta", title: "仮説の人物像の詳細は Insight で読めます", copy: "抽象ポートレートは公開しつつ、仕事の進め方や動きやすい場面は利用登録後に表示します。" %>
        <% end %>
      </div>
    </div>
  </article>
</section>

<section class="dashboard-grid">
  <% capability_profile = @person_public_estimate[:capability_profile] || {} %>
  <article class="panel soft-panel relationship-panel relationship-panel--wide person-estimate-panel">
    <p class="eyebrow">Public Estimate</p>
    <h2>公開情報ベースの見立て</h2>
    <p class="meta"><%= @person_public_estimate[:notice] %></p>

    <div class="person-estimate-grid">
      <article class="person-estimate-card">
        <h3>職業・役割候補</h3>
        <% if @person_public_estimate[:roles].any? %>
          <div class="tag-cloud">
            <% @person_public_estimate[:roles].each do |role| %>
              <span class="tag-pill person-estimate-pill"><%= role %></span>
            <% end %>
          </div>
        <% else %>
          <p class="empty-note">役割候補はまだ十分に推定できません。</p>
        <% end %>
      </article>

      <article class="person-estimate-card">
        <h3>活動テーマ</h3>
        <% if @person_public_estimate[:themes].any? %>
          <div class="tag-cloud">
            <% @person_public_estimate[:themes].each do |theme| %>
              <span class="tag-pill"><%= theme %></span>
            <% end %>
          </div>
        <% else %>
          <p class="empty-note">テーマ情報を追加すると見立てが安定します。</p>
        <% end %>
      </article>

      <article class="person-estimate-card">
        <h3>関係の持ち方</h3>
        <p class="person-estimate-label"><%= @person_public_estimate.dig(:network_position, :label) %></p>
        <p class="person-lens-copy"><%= @person_public_estimate.dig(:network_position, :reason) %></p>
      </article>

      <article class="person-estimate-card">
        <h3>会うときの入口</h3>
        <p class="person-estimate-label"><%= @person_public_estimate.dig(:approach, :label) %></p>
        <p class="person-lens-copy"><%= @person_public_estimate.dig(:approach, :reason) %></p>
      </article>

      <article class="person-estimate-card person-estimate-card--wide capability-profile-card">
        <h3>活動特性スケール</h3>
        <p class="meta"><%= capability_profile[:notice] %></p>
        <div class="capability-profile-grid">
          <% Array(capability_profile[:metrics]).each do |metric| %>
            <article class="capability-profile-item">
              <div class="capability-profile-head">
                <strong><%= metric[:label] %></strong>
                <span class="meta"><%= "#{metric[:value]}/#{metric[:max]}" %></span>
              </div>
              <div class="capability-meter" aria-hidden="true">
                <span class="capability-meter-fill" style="width: <%= metric[:percent] %>%"></span>
              </div>
              <p class="capability-profile-reason"><%= metric[:reason] %></p>
            </article>
          <% end %>
        </div>
      </article>

      <article class="person-estimate-card person-estimate-card--wide">
        <h3>根拠</h3>
        <% if @person_public_estimate[:evidence].any? %>
          <ul class="person-lens-detail-list">
            <% @person_public_estimate[:evidence].each do |point| %>
              <li><%= point %></li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-note">タグ、所属、関係データが増えると根拠も表示されます。</p>
        <% end %>
      </article>
    </div>
  </article>
</section>

<section class="dashboard-grid">
  <article
    class="panel soft-panel relationship-panel relationship-panel--wide"
    data-controller="relationship-depth"
    data-relationship-depth-active-depth-value="<%= @graph_depth %>">
    <% depth_options = [
      { value: 1, title: "1階層" },
      { value: 2, title: "2階層" },
      { value: 3, title: "3階層" }
    ] %>
    <p class="eyebrow">Person Lens</p>
    <h2>人物起点マップ</h2>
    <p class="meta">人物関係図を入口に、この人物に近い人、越境的につながる人、次に追うべき人へ進みます。</p>
    <div class="relationship-map-layout">
      <div class="relationship-depth-rail">
        <div class="relationship-depth-picker" role="navigation" aria-label="人物関係図の表示範囲">
          <% depth_options.each do |option| %>
            <% active = @graph_depth == option[:value] %>
            <button
              type="button"
              class="relationship-depth-option<%= ' is-active' if active %>"
              data-action="relationship-depth#switch"
              data-relationship-depth-target="option"
              data-depth="<%= option[:value] %>"
              aria-pressed="<%= active ? "true" : "false" %>">
              <strong class="relationship-depth-label"><%= option[:title] %></strong>
            </button>
          <% end %>
        </div>
      </div>
      <div class="relationship-depth-panels">
        <% depth_options.each do |option| %>
          <% active = @graph_depth == option[:value] %>
          <section
            class="relationship-depth-panel<%= ' is-active' if active %>"
            data-relationship-depth-target="panel"
            data-depth="<%= option[:value] %>"
            <%= "hidden" unless active %>>
            <%= render "shared/relationship_graph", graph: @relationship_graphs.fetch(option[:value]), empty_message: "この人物に関連する別の人物が増えると関係図を表示できます。" %>
          </section>
        <% end %>
      </div>
    </div>
  </article>

</section>

<section class="dashboard-grid person-lens-grid person-lens-grid--exploration">
  <article class="panel soft-panel person-lens-card">
    <p class="eyebrow">Related People</p>
    <h2>主要関係者</h2>
    <p class="meta">この人を理解するうえで先に押さえたい関係者です。強い接点から順に見られます。</p>
    <% if @person_navigation_lens[:primary_people].any? %>
      <ul class="person-lens-list">
        <% @person_navigation_lens[:primary_people].each do |connection| %>
          <li class="person-lens-item">
            <div class="person-lens-head">
              <%= link_to connection[:label], connection[:href] %>
              <span class="tag-pill"><%= connection[:kind_label] %></span>
            </div>
            <p class="meta"><%= [ connection[:tone_label], connection[:strength_label] ].join(" / ") %></p>
            <p class="person-lens-copy"><%= connection[:reason] %></p>
            <% if connection[:shared_tags].any? || connection[:shared_organizations].any? %>
              <div class="tag-cloud person-lens-tags">
                <% connection[:shared_tags].each do |tag_name| %>
                  <span class="tag-pill person-context-pill"><%= "共通テーマ: #{tag_name}" %></span>
                <% end %>
                <% connection[:shared_organizations].each do |organization_name| %>
                  <span class="tag-pill person-context-pill"><%= "共通所属: #{organization_name}" %></span>
                <% end %>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-note">まだこの人物の主要関係者は十分に見つかっていません。</p>
    <% end %>
  </article>

  <article class="panel soft-panel person-lens-card">
    <p class="eyebrow">Why Connected</p>
    <h2>関係の理由</h2>
    <p class="meta">接点の強さ、テーマ、所属のどこで関係が生まれているかを短く読めます。</p>
    <% if deep_insight %>
      <% if @person_navigation_lens[:relation_reasons].any? %>
        <ul class="person-lens-list">
          <% @person_navigation_lens[:relation_reasons].each do |connection| %>
            <li class="person-lens-item">
              <div class="person-lens-head">
                <%= link_to connection[:label], connection[:href] %>
                <span class="tag-pill"><%= connection[:kind_label] %></span>
              </div>
              <p class="person-lens-copy"><%= connection[:reason] %></p>
              <% if connection[:relation_points].any? %>
                <ul class="person-lens-detail-list">
                  <% connection[:relation_points].each do |point| %>
                    <li><%= point %></li>
                  <% end %>
                </ul>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-note">まだ関係理由を説明できる十分な材料がありません。</p>
      <% end %>
    <% else %>
      <p class="insight-locked-copy"><%= @person_navigation_lens[:relation_reasons].any? ? "#{@person_navigation_lens[:relation_reasons].size}件の関係理由があります。どの接点・テーマ・所属でつながるかの全文は登録後に読めます。" : "関係理由はデータが増えると表示されます。全文表示は登録後に読めます。" %></p>
      <%= render "shared/insight_membership_cta", title: "関係の理由は Insight で読めます", copy: "人物同士がなぜつながるのかを文章で読む部分は、利用登録後の深掘りです。" %>
    <% end %>
  </article>

  <article class="panel soft-panel person-lens-card">
    <p class="eyebrow">Next People</p>
    <h2>次に見るべき人物</h2>
    <p class="meta">この人の周辺を広げるなら、次にたどる価値が高い人物です。</p>
    <% if deep_insight %>
      <% if @person_navigation_lens[:next_people].any? %>
        <ul class="person-lens-list">
          <% @person_navigation_lens[:next_people].each do |connection| %>
            <li class="person-lens-item">
              <div class="person-lens-head">
                <%= link_to connection[:label], connection[:href] %>
                <span class="tag-pill"><%= connection[:kind_label] %></span>
              </div>
              <p class="meta"><%= [ connection[:tone_label], connection[:strength_label] ].join(" / ") %></p>
              <p class="person-lens-copy"><%= connection[:next_step_reason] %></p>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-note">次に追うべき人物候補は、関係データが増えると表示されます。</p>
      <% end %>
    <% else %>
      <p class="insight-locked-copy"><%= @person_navigation_lens[:next_people].any? ? "次にたどる価値が高い人物候補が#{@person_navigation_lens[:next_people].size}人あります。選定理由は登録後に読めます。" : "人物候補は関係データが増えると表示されます。選定理由は登録後に読めます。" %></p>
      <%= render "shared/insight_membership_cta", title: "次に見るべき人物は Insight で読めます", copy: "どの人物を次に追うべきか、その理由ごと読む部分は利用登録後に表示します。" %>
    <% end %>
  </article>
</section>

<section class="dashboard-grid">
  <article class="panel soft-panel">
    <p class="eyebrow">Summary</p>
    <h2>人物概要</h2>
    <%= simple_format(@resolved_person_profile[:summary].presence || "要約未設定") %>
    <p><strong>本文:</strong></p>
    <%= simple_format(@resolved_person_profile[:bio].presence || "本文未設定") %>

    <div class="tag-cloud">
      <% if @resolved_person_profile[:tags].any? %>
        <% @resolved_person_profile[:tags].each do |tag| %>
          <span class="tag-pill"><%= tag %></span>
        <% end %>
      <% else %>
        <span class="tag-pill muted">タグ未設定</span>
      <% end %>
    </div>
  </article>
</section>

<section class="dashboard-grid">
  <article class="panel soft-panel">
    <p class="eyebrow">Wiki Notes</p>
    <h2>追記メモ</h2>

    <% if can_edit_content? %>
      <%= form_with url: research_notes_path do |form| %>
        <%= form.hidden_field :person_id, value: @person.id, name: "research_note[person_id]" %>

        <div class="field">
          <%= form.label :note_kind, "メモ種別" %>
          <%= form.select :note_kind, ResearchNote::NOTE_KINDS.map { |value| [ value.humanize, value ] }, {}, name: "research_note[note_kind]" %>
        </div>

        <div class="field">
          <%= form.label :body, "内容" %>
          <%= form.text_area :body, rows: 4, required: true, name: "research_note[body]" %>
        </div>

        <%= form.submit "メモを残す", class: "primary-button" %>
      <% end %>

      <% if @research_notes.any? %>
        <ul class="stack-list note-list">
          <% @research_notes.each do |note| %>
            <li class="timeline-card">
              <strong><%= note.note_kind.humanize %></strong>
              <div><%= simple_format(note.body) %></div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty-note">まだ追記メモはありません。補足や仮説を残してください。</p>
      <% end %>
    <% else %>
      <p class="empty-note">追記メモの閲覧と記入は、編集者ログイン後に利用できます。</p>
    <% end %>
  </article>
</section>

<section class="dashboard-grid">
  <article class="panel soft-panel">
    <p class="eyebrow">External Sources</p>
    <h2>外部データ源</h2>
    <p class="meta">
      <%= external_profile_mode_label(@resolved_person_profile[:source_mode]) %>
      <% if @resolved_person_profile[:source_error].present? %>
        / 取得失敗: <%= @resolved_person_profile[:source_error] %>
      <% end %>
    </p>
    <% if @person.person_external_profiles.any? %>
      <ul class="stack-list soft-list">
        <% @person.person_external_profiles.order(:source_name).each do |profile| %>
          <li>
            <strong><%= external_source_label(profile.source_name) %></strong>
            <span class="meta"><%= profile.external_id %> / <%= l(profile.fetched_at, format: :short) %></span>
            <div><%= link_to profile.source_url, profile.source_url, target: "_blank", rel: "noreferrer" %></div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-note">まだ外部データとは紐付いていません。必要なら外部DBから補強できます。</p>
    <% end %>
  </article>
</section>
