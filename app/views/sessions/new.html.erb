<% content_for :title, "編集ログイン" %>

<section class="entry-layout">
  <aside class="entry-aside">
    <p class="ribbon-label">Editorial Access</p>
    <h1 class="hero-title small">人物録の編集を、<br>また始める。</h1>
    <p class="lede">
      注目人物、取材メモ、公開プロフィールの整理を、
      続きから再開するためのログインです。
    </p>
    <div class="aside-badges">
      <span class="feature-pill">editorial desk</span>
      <span class="feature-pill">research notes</span>
    </div>
  </aside>

  <section class="form-panel narrow cute-frame">
    <p class="eyebrow">Editor Sign In</p>
    <h2>編集ログイン</h2>

    <%= form_with scope: :session, url: sign_in_path do |form| %>
      <div class="field">
        <%= form.label :email, "メールアドレス" %>
        <%= form.email_field :email, required: true, autofocus: true, placeholder: "you@example.com" %>
      </div>

      <div class="field">
        <%= form.label :password, "パスワード" %>
        <%= form.password_field :password, required: true, placeholder: "password" %>
      </div>

      <%= form.submit "編集画面に入る", class: "primary-button" %>
    <% end %>
  </section>
</section>
