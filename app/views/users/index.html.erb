<% content_for :title, "人物録" %>

<section class="page-header dreamy-header">
  <div>
    <p class="ribbon-label">Directory</p>
    <h1>人物録</h1>
    <p class="lede compact">名前、所属、役割、タグから、出会いの先で何かをより良くしていそうな人物を探します。</p>
  </div>
</section>

<section class="panel soft-panel">
  <%= form_with url: users_path, method: :get, class: "inline-form" do |form| %>
    <%= form.search_field :q, value: @query, placeholder: "名前、所属、役割、タグで検索" %>
    <%= form.submit "検索", class: "primary-button" %>
  <% end %>
</section>

<section class="results-grid">
  <% @users.each do |user| %>
    <article class="panel result-card">
      <p class="eyebrow">Entry</p>
      <h2><%= link_to user.profile.display_name, user_path(user) %></h2>
      <p class="meta"><%= user.profile.organization.presence || "所属未設定" %> / <%= user.profile.role.presence || "役割未設定" %></p>
      <p><%= truncate(user.profile.bio.presence || "自己紹介未設定", length: 100) %></p>
      <div class="tag-cloud">
        <% if user.profile.tags.any? %>
          <% user.profile.tags.order(:name).each do |tag| %>
            <span class="tag-pill"><%= tag.name %></span>
          <% end %>
        <% else %>
          <span class="tag-pill muted">タグ未設定</span>
        <% end %>
      </div>
    </article>
  <% end %>

  <% if @users.empty? %>
    <article class="panel empty-state">
      <p>条件に一致する公開人物録が見つかりませんでした。出会いのきっかけになりそうな別のキーワードで探してみてください。</p>
    </article>
  <% end %>
</section>
