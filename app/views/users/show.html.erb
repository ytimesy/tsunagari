<% content_for :title, @user.profile.display_name %>

<section class="profile-hero">
  <div class="profile-badge">
    <p class="ribbon-label">Person Record</p>
    <h1><%= @user.profile.display_name %></h1>
    <p class="meta"><%= @user.profile.organization.presence || "所属未設定" %> / <%= @user.profile.role.presence || "役割未設定" %></p>
    <div class="status-petal"><%= visibility_label(@user.profile.visibility_level) %></div>
  </div>

  <% if user_signed_in? && current_user != @user %>
    <% if current_user.favorites.exists?(target_user: @user) %>
      <%= button_to "注目解除", user_favorite_path(@user), method: :delete, class: "ghost-button" %>
    <% else %>
      <%= button_to "注目人物に入れる", user_favorite_path(@user), method: :post, class: "primary-button" %>
    <% end %>
  <% end %>
</section>

<section class="dashboard-grid">
  <article class="panel soft-panel">
    <p class="eyebrow">Published Entry</p>
    <h2>掲載プロフィール</h2>
    <p><strong>自己紹介:</strong></p>
    <%= simple_format(@user.profile.bio.presence || "未設定") %>
    <div class="tag-cloud">
      <% if @user.profile.tags.any? %>
        <% @user.profile.tags.order(:name).each do |tag| %>
          <span class="tag-pill"><%= tag.name %></span>
        <% end %>
      <% else %>
        <span class="tag-pill muted">タグ未設定</span>
      <% end %>
    </div>
  </article>

  <% if user_signed_in? && current_user != @user %>
    <article class="panel soft-panel">
      <p class="eyebrow">Editorial Notes</p>
      <h2>取材メモ</h2>

      <%= form_with model: [ @user, EncounterNote.new ] do |form| %>
        <div class="field">
          <%= form.label :encountered_on, "関係が生まれた日" %>
          <%= form.date_field :encountered_on %>
        </div>

        <div class="field">
          <%= form.label :encounter_place, "現場・媒体・場所" %>
          <%= form.text_field :encounter_place %>
        </div>

        <div class="field">
          <%= form.label :note, "観点メモ" %>
          <%= form.text_area :note, rows: 4, required: true %>
        </div>

        <div class="field">
          <%= form.label :next_action, "次に掘ること" %>
          <%= form.text_area :next_action, rows: 3 %>
        </div>

        <%= form.submit "取材メモを残す", class: "primary-button" %>
      <% end %>

      <% notes = current_user.authored_encounter_notes.where(subject_user: @user).order(encountered_on: :desc, created_at: :desc) %>
      <% if notes.any? %>
        <ul class="stack-list note-list">
          <% notes.each do |note| %>
            <li class="timeline-card">
              <strong><%= note.encountered_on || "日付未設定" %></strong>
              <span class="meta"><%= note.encounter_place.presence || "場所未設定" %></span>
              <div><%= simple_format(note.note) %></div>
              <% if note.next_action.present? %>
                <p class="meta">次に掘ること: <%= note.next_action %></p>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </article>
  <% end %>
</section>
